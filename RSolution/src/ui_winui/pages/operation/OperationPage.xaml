<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RSolution.OperationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RSolution"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="GreenDot" Color="#5BBA6F"/>
        <SolidColorBrush x:Key="RedDot" Color="#E2574C"/>
        <SolidColorBrush x:Key="TitleText" Color="#2C3E50"/>
        <SolidColorBrush x:Key="SubText" Color="#9AA0A6"/>
        <SolidColorBrush x:Key="CardBg" Color="#F4F4F4"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="#E6E6E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TitleText}"/>
        </Style>
    </Page.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HMI 헤더 ===== -->
        <TextBlock Grid.Row="0" Text="HMI" FontSize="34" FontWeight="SemiBold"
                   Foreground="#222222" Margin="28,18,0,6"/>

        <!-- ===== 본문 ===== -->
        <Grid Grid.Row="1" Margin="28,6,28,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="2,0,0,12">
                <TextBlock Text="SYSTEM STATUS" FontSize="20" FontWeight="SemiBold"
                           Foreground="#444444" HorizontalAlignment="Left"/>
                <TextBlock x:Name="EquipmentStateText" Text="State: PowerOff" FontSize="16"
                           Foreground="#6B7785" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== Card 1: Wafers ===== -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Wafers" Style="{StaticResource CardTitle}" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Ellipse Width="13" Height="13" Fill="{StaticResource GreenDot}"/>
                                <TextBlock Text="Normal" FontSize="18" Foreground="#444444"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Spacing="16" VerticalAlignment="Top">
                            <!-- Wafer 1 -->
                            <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
                                <Ellipse Width="96" Height="64" Fill="#B6E0A6" Stroke="#94C77F" StrokeThickness="3"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Wafer 1" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TitleText}"/>
                                    <TextBlock Text="Wafers" FontSize="15" Foreground="{StaticResource SubText}"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- Wafer 2 (alarm) -->
                            <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
                                <Ellipse Width="96" Height="64" Fill="#EAB0AA" Stroke="#DD9C94" StrokeThickness="3"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Wafer 2" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TitleText}"/>
                                    <TextBlock Text="Wafers" FontSize="15" Foreground="{StaticResource SubText}"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- Wafer 3 + 상태 -->
                            <Grid>
                                <Ellipse Width="96" Height="64" Fill="#B6E0A6" Stroke="#94C77F" StrokeThickness="3" HorizontalAlignment="Left"/>
                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="14">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="Standby" FontSize="18" Foreground="{StaticResource TitleText}"/>
                                        <Ellipse Width="13" Height="13" Fill="{StaticResource GreenDot}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="Alarm" FontSize="18" Foreground="{StaticResource TitleText}"/>
                                        <Ellipse Width="13" Height="13" Fill="{StaticResource RedDot}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== Card 2: Load Port ===== -->
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBlock Text="Load Port" Style="{StaticResource CardTitle}" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Ellipse Width="13" Height="13" Fill="{StaticResource GreenDot}"/>
                                <TextBlock Text="Standby" FontSize="18" Foreground="#444444"/>
                            </StackPanel>
                        </Grid>

                        <!-- 로봇 암 (에셋 없이 이모지로 근사) -->
                        <Viewbox Grid.Row="1" MaxHeight="170" Margin="0,12">
                            <TextBlock Text="&#x1F9BE;" FontSize="120"/>
                        </Viewbox>

                        <Grid Grid.Row="2" RowSpacing="16" ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Normal" FontSize="18" Foreground="{StaticResource TitleText}"/>
                                    <Ellipse Width="13" Height="13" Fill="{StaticResource GreenDot}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Normal" FontSize="15" Foreground="{StaticResource SubText}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Standby" FontSize="18" Foreground="{StaticResource TitleText}"/>
                                    <Ellipse Width="13" Height="13" Fill="{StaticResource GreenDot}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Idle" FontSize="15" Foreground="{StaticResource SubText}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Idle" FontSize="18" Foreground="{StaticResource TitleText}"/>
                                    <Ellipse Width="13" Height="13" Fill="{StaticResource GreenDot}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Idle" FontSize="15" Foreground="{StaticResource SubText}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Alarm" FontSize="18" Foreground="{StaticResource TitleText}"/>
                                    <Ellipse Width="13" Height="13" Fill="{StaticResource RedDot}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Alarm" FontSize="15" Foreground="{StaticResource SubText}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ===== Card 3: Process ===== -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Process" Style="{StaticResource CardTitle}" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Ellipse Width="13" Height="13" Fill="{StaticResource RedDot}"/>
                                <TextBlock Text="Alarm" FontSize="18" Foreground="#444444"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Spacing="4">
                            <!-- item 1 -->
                            <Grid Padding="4,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Background="#E2E2E2">
                                    <SymbolIcon Symbol="Share" Foreground="#6B7785"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Process 1" FontSize="19" FontWeight="SemiBold" Foreground="{StaticResource TitleText}"/>
                                    <TextBlock Text="Process 1" FontSize="14" Foreground="{StaticResource SubText}"/>
                                </StackPanel>
                                <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="16" Foreground="#9AA0A6" VerticalAlignment="Center"/>
                            </Grid>
                            <!-- item 2 -->
                            <Grid Padding="4,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Background="#E2E2E2">
                                    <SymbolIcon Symbol="Download" Foreground="#6B7785"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Process 1" FontSize="19" FontWeight="SemiBold" Foreground="{StaticResource TitleText}"/>
                                    <TextBlock Text="Process 1" FontSize="14" Foreground="{StaticResource SubText}"/>
                                </StackPanel>
                                <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="16" Foreground="#9AA0A6" VerticalAlignment="Center"/>
                            </Grid>
                            <!-- item 3 -->
                            <Grid Padding="4,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Background="#E2E2E2">
                                    <SymbolIcon Symbol="List" Foreground="#6B7785"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Process 2" FontSize="19" FontWeight="SemiBold" Foreground="{StaticResource TitleText}"/>
                                    <TextBlock Text="Process 1" FontSize="14" Foreground="{StaticResource SubText}"/>
                                </StackPanel>
                                <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="16" Foreground="#9AA0A6" VerticalAlignment="Center"/>
                            </Grid>
                            <!-- item 4 -->
                            <Grid Padding="4,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Background="#E2E2E2">
                                    <SymbolIcon Symbol="List" Foreground="#6B7785"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Process 2" FontSize="19" FontWeight="SemiBold" Foreground="{StaticResource TitleText}"/>
                                    <TextBlock Text="Process 2" FontSize="14" Foreground="{StaticResource SubText}"/>
                                </StackPanel>
                                <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="16" Foreground="#9AA0A6" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== 하단 알람 바 ===== -->
        <Border x:Name="AlarmBar" Grid.Row="2" Background="#5BBA6F" CornerRadius="6" Margin="28,0,28,20" Padding="22,14">
            <Grid>
                <TextBlock x:Name="AlarmText" Text="No active alarm" Foreground="White" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock x:Name="TimeText" Text="08:00 AM" Foreground="White" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Page>
