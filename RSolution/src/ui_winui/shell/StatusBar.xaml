<?xml version="1.0" encoding="utf-8"?>
<!-- UI 문서 v2 2장: 하단 공통 알람 영역 - 최신 알람 표시 + Ack / Reset / Buzzer Off -->
<Page
    x:Class="RSolution.StatusBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RSolution"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootBar" Height="52" Background="#ECF0F1" Padding="16,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <FontIcon x:Name="AlarmIcon" Glyph="&#xE7BA;" FontSize="18"
                  Foreground="#7F8C99" VerticalAlignment="Center" Margin="0,0,10,0"/>

        <TextBlock x:Name="AlarmText" Grid.Column="1" Text="No Active Alarm"
                   Foreground="#5D6D7E" FontSize="14" VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"/>

        <!-- 조작 버튼: 실행 시 Application 계층에서 권한·상태를 재검증한다(UI 문서 1장/6장). -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button x:Name="AckButton" Content="Ack" MinWidth="72" Click="AckClick"/>
            <Button x:Name="ResetButton" Content="Reset" MinWidth="72" Click="ResetClick"/>
            <Button x:Name="BuzzerOffButton" Content="Buzzer Off" MinWidth="88" Click="BuzzerOffClick"/>
        </StackPanel>
    </Grid>
</Page>
