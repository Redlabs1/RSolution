<?xml version="1.0" encoding="utf-8"?>
<!-- UI 문서 v2 2장: 상단 공통 상태 영역 - EQP ID, 장비 상태, AUTO/MANUAL, 사용자·권한, Host/PLC, 시간 -->
<Page
    x:Class="RSolution.HeaderPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RSolution"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Height="48" Background="#22303F" Padding="16,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 좌: 장비 식별 + 상태 배지 + 운전 모드 -->
        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock x:Name="EqpIdText" Text="EQP-01"
                       Foreground="#ECF0F1" FontSize="16" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Border x:Name="StateBadge" Background="#566573" CornerRadius="4" Padding="12,4">
                <TextBlock x:Name="StateText" Text="INIT"
                           Foreground="White" FontWeight="SemiBold" FontSize="14"/>
            </Border>
            <Border Background="#3B5066" CornerRadius="4" Padding="12,4">
                <TextBlock x:Name="ModeText" Text="MANUAL"
                           Foreground="#ECF0F1" FontWeight="SemiBold" FontSize="14"/>
            </Border>
        </StackPanel>

        <!-- 우: 사용자(권한), Host/PLC 연결, 시간 -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
            <TextBlock x:Name="UserText" Text="User: -" Foreground="#ECF0F1" FontSize="14"/>
            <TextBlock x:Name="HostText" Text="Host: OFFLINE" Foreground="#E67E22" FontSize="14"/>
            <TextBlock x:Name="PlcText" Text="PLC: -" Foreground="#E67E22" FontSize="14"/>
            <TextBlock x:Name="TimeText" Text="--:--:--" Foreground="#ECF0F1" FontSize="14"/>
        </StackPanel>
    </Grid>
</Page>
